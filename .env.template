# App config
NODE_ENV=local


# Frontend related
FRONTEND_BACKEND_BASE_URL=http://localhost:3001

# Backend related
BACKEND_PORT=3001
BACKEND_BUILD_MODE=swc
BACKEND_CLIENT_HOST=http://localhost:3000
BACKEND_COOKIE_SECRET=something_secret
BACKEND_COOKIE_DOMAIN_NAME=localhost

# Backend feature flag
BACKEND_ENABLE_API_TEST_MODE=false # Set to 'true' when running API test


# Database related
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=Password1234
DATABASE_DB=project_db

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Firebase Admin SDK
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Email provider
EMAIL_PROVIDER="postmark"
POSTMARK_API_KEY=your-postmark-api-key
POSTMARK_FROM_ADDRESS=no-reply@yourdomain.com
AWS_SES_REGION="us-east-1"
AWS_SES_FROM_ADDRESS=no-reply@yourdomain.com

# Maintenance thresholds
MILEAGE_WARNING_THRESHOLD_KM="500"
NOTIFICATION_DAYS_BEFORE="7"
NOTIFICATION_CRON_SCHEDULE="0 8 * * *"

# Firebase (frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=your-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id