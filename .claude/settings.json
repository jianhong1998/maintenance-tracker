{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "deny": [
      "Read(**/.env)",
      "Bash(*cat */.env*)",
      "Bash(*cat .env*)",
      "Bash(*head */.env*)",
      "Bash(*head .env*)",
      "Bash(*tail */.env*)",
      "Bash(*tail .env*)",
      "Bash(*less */.env*)",
      "Bash(*less .env*)",
      "Bash(*more */.env*)",
      "Bash(*more .env*)",
      "Bash(*tac */.env*)",
      "Bash(*tac .env*)",
      "Bash(*nl */.env*)",
      "Bash(*nl .env*)",
      "Bash(*grep */.env*)",
      "Bash(*grep .env*)",
      "Bash(*rg */.env*)",
      "Bash(*rg .env*)",
      "Bash(*awk */.env*)",
      "Bash(*awk .env*)",
      "Bash(*sed */.env*)",
      "Bash(*sed .env*)",
      "Bash(*cut */.env*)",
      "Bash(*cut .env*)",
      "Bash(*xxd */.env*)",
      "Bash(*xxd .env*)",
      "Bash(*hexdump */.env*)",
      "Bash(*hexdump .env*)",
      "Bash(*od */.env*)",
      "Bash(*od .env*)",
      "Bash(*strings */.env*)",
      "Bash(*strings .env*)",
      "Bash(*python* .env*)",
      "Bash(*python*/.env*)",
      "Bash(*node* .env*)",
      "Bash(*node*/.env*)",
      "Bash(*perl* .env*)",
      "Bash(*perl*/.env*)",
      "Bash(*ruby* .env*)",
      "Bash(*ruby*/.env*)",
      "Bash(*source .env*)",
      "Bash(*source */.env*)",
      "Bash(*. .env*)",
      "Bash(*. */.env*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true
  }
}
